{
	"name": "next-blank",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"postinstall": "mkdir -p public/workers && cp node_modules/pdfjs-dist/build/pdf.worker.min.mjs public/workers/",
		"dev": "node server.js dev",
		"start": "node server.js start",
		"build": "next build",
		"lint": "eslint .",
		"typecheck": "tsc --noEmit",
		"fix": "eslint --fix .",
		"format": "prettier --config .prettierrc --log-level silent --write \"**/*.{js,jsx,mjs,cjs,ts,tsx,css,scss,less,json,yml,yaml,md}\"",
		"deps:upgrade": "pnpm up --latest",
		"deps:reset": "rm -rf node_modules .next pnpm-lock.yaml && pnpm store prune && pnpm install"
	},
	"dependencies": {
		"@types/pdfmake": "^0.3.3",
		"next": "^16.2.6",
		"pdfjs-dist": "^5.7.284",
		"pdfmake": "^0.3.9",
		"react": "^19.2.6",
		"react-dom": "^19.2.6"
	},
	"devDependencies": {
		"@eslint-react/eslint-plugin": "^5.8.6",
		"@eslint/js": "^10.0.1",
		"@next/eslint-plugin-next": "^16.2.6",
		"@stylistic/eslint-plugin": "^5.10.0",
		"@types/node": "^25.9.1",
		"@types/react": "^19.2.15",
		"@types/react-dom": "^19.2.3",
		"eslint": "^10.4.0",
		"eslint-plugin-import-x": "^4.16.2",
		"globals": "^17.6.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.0"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "pnpm@11.4.0+sha512.f0febc7e37552ab485494a914241b338e0b3580b93d54ce31f00933015880863129038a1b4ae4e414a0ee63ac35bf21197e990172c4a68256450b5636310968f",
	"browserslist": [
